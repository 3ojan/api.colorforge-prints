# Copy to .env and fill in values
# Stripe (required)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# mer (moj-eRačun) - invoice sent to customer after payment
# API: https://legacy-mer.moj-eracun.hr/en/Manual/Stable/Api
MER_API_URL=https://legacy-mer.moj-eracun.hr
MER_USERNAME=your_mer_username
MER_PASSWORD=your_mer_password
MER_SOFTWARE_ID=your_registered_software_id
COMPANY_OIB=12345678901
COMPANY_NAME=Your Company
COMPANY_ADDRESS=Street 1
COMPANY_CITY=Zagreb
COMPANY_POSTAL_CODE=10000

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:8080

# MySQL (optional – omit to skip DB)
DB_HOST=localhost
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

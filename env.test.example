# Copy to server/.env for testing
# Fill in your real values - these are placeholders

# Stripe (required) - get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>

# mer (moj-eRačun) - get from https://portal.moj-eracun.hr
MER_API_URL=https://legacy-mer.moj-eracun.hr
MER_USERNAME=your_mer_username
MER_PASSWORD=your_mer_password
MER_SOFTWARE_ID=your_registered_software_id

# Company (your business)
COMPANY_OIB=90027180115
COMPANY_NAME=3ojn STUDIO d.o.o.
COMPANY_ADDRESS=Novačka 343
COMPANY_CITY=Zagreb
COMPANY_POSTAL_CODE=10000

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:8080

# MySQL (optional - omit to skip)
# DB_HOST=localhost
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
